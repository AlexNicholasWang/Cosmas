{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "backend/prompt.py": {
      "runtime": "vercel-python@0.0.6"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/prompt.py"
    }
  ]
}
